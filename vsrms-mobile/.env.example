# ── Backend API ──────────────────────────────────────────────────────────────
# Full URL to your hosted or local backend, including /api/v1
# Example: https://vsrms.onrender.com/api/v1
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# ── Asgardeo (Mobile Authentication) ─────────────────────────────────────────
# These must match your Asgardeo Application settings for OIDC flow
EXPO_PUBLIC_ASGARDEO_ORG_NAME=your_organization_name
EXPO_PUBLIC_ASGARDEO_CLIENT_ID=your_client_id
